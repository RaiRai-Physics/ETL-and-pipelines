-- =========================
-- 13) Export employee data as Parquet to S3
-- =========================
COPY INTO @listing_stage/employee_parquet_
FROM (
    SELECT
        EMPLOYEE_ID,
        NAME,
        SALARY,
        DEPARTMENT_ID,
        JOINING_DATE
    FROM employee_parquet_source
)
FILE_FORMAT = (TYPE = 'PARQUET')
HEADER = TRUE
OVERWRITE = TRUE;

-- =========================
-- 14) Verify Parquet file exists in S3 stage
-- =========================
LIST @listing_stage;

-- =========================
-- 15) Create Parquet file format
-- =========================
CREATE OR REPLACE FILE FORMAT parquet_format
TYPE = 'PARQUET';

-- =========================
-- 16) Preview Parquet data
-- =========================
SELECT $1
FROM @listing_stage
(FILE_FORMAT => parquet_format)
LIMIT 10;

-- =========================
-- 17) Create destination table
-- =========================
CREATE OR REPLACE TABLE Employee_Parquet_Loaded (
    EMPLOYEE_ID INT,
    NAME VARCHAR(100),
    SALARY DECIMAL(10,2),
    DEPARTMENT_ID INT,
    JOINING_DATE DATE
);

-- =========================
-- 18) Load Parquet into destination table
-- =========================
COPY INTO Employee_Parquet_Loaded
FROM @listing_stage
FILE_FORMAT = (FORMAT_NAME = parquet_format)
MATCH_BY_COLUMN_NAME = CASE_INSENSITIVE;

-- =========================
-- 19) Verify loaded data
-- =========================
SELECT * FROM Employee_Parquet_Loaded;

SELECT COUNT(*) FROM Employee_Parquet_Loaded;
